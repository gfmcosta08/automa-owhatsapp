PORT=3000
NODE_ENV=production
DATABASE_URL=postgresql://user:pass@host:5432/dbname
REDIS_URL=redis://localhost:6379

WEBHOOK_BASE_URL=https://seudominio.com
CORS_ORIGIN=

ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
SETTINGS_ENCRYPTION_KEY=
INTERNAL_NOTIFY_SECRET=

# auto | uazapi | meta — auto escolhe UazAPI se houver token de instância
WHATSAPP_PROVIDER=auto

# UazAPI (envio: POST {base}/send/text?token=...)
UAZAPI_BASE_URL=https://focus.uazapi.com
UAZAPI_INSTANCE_TOKEN=
UAZAPI_ADMIN_TOKEN=
UAZAPI_INSTANCE_PHONE=

# Legado Meta Cloud API (só com WHATSAPP_PROVIDER=meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

ENABLE_AGENDAMENTO=true
SUPERADMIN=false
