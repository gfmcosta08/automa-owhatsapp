# API Express (porta padrão 3000)
PORT=3000
DATABASE_URL=
REDIS_URL=

# Agendamento — UI /access (Next em http://localhost:3001)
ENABLE_AGENDAMENTO=true
SUPERADMIN=false
# CORS_ORIGIN obrigatório em produção para habilitar CORS na API.
# Sem ele, CORS fica desativado (origin: false). Separe múltiplas origens com vírgula.
CORS_ORIGIN=http://localhost:3001

# Webhook por empresa — URL base pública da API (sem barra no final)
# URLs exibidas no admin: WEBHOOK_BASE_URL/webhook/whatsapp (Meta) e .../webhook/entrada/{token} (oazap)
WEBHOOK_BASE_URL=https://seudominio.com

# Painel /admin — se definido, exige login (senha em texto; use HTTPS em produção)
ADMIN_PASSWORD=
# Opcional: assinatura do cookie de sessão (padrão: INTERNAL_NOTIFY_SECRET)
ADMIN_SESSION_SECRET=

# Criptografia dos segredos gravados pelo admin (access token e app secret do WhatsApp)
# 32 bytes em hex (64 caracteres) ou base64; em dev, sem chave os segredos ficam em base64 marcado (não use em produção)
SETTINGS_ENCRYPTION_KEY=

# Notificações internas (e fallback de ADMIN_SESSION_SECRET)
INTERNAL_NOTIFY_SECRET=

# WhatsApp Cloud API — fallback quando o banco ainda não tem credenciais (admin pode gravar no painel)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
